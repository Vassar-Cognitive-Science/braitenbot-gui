{
  "name": "braitenbot-gui",
  "version": "0.6.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:playground": "vite build --config vite.playground.config.ts",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p relay/tsconfig.json",
    "relay:dev": "tsx relay/src/index.ts",
    "relay:build": "tsc -p relay/tsconfig.build.json",
    "fetch:arduino-cli": "node scripts/fetch-arduino-cli.mjs",
    "fetch:arduino-cli:all": "node scripts/fetch-arduino-cli.mjs --all",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.1.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.5",
    "tsx": "^4.23.0",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.4",
    "ws": "^8.21.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
